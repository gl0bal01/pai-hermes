#!/usr/bin/env bash
# pai-accept-guard — SSH-only + flock + atomic paths.env mutation
#
# The pai-accept skill describes this flow in markdown, but Hermes is an
# LLM-driven agent: it could be persuaded to bypass markdown rules. This
# wrapper enforces the security model in shell, not prose.
#
# Usage:
#   pai-accept-guard <proposal-id>
#
# Exit codes:
#   0   accepted
#   1   generic failure
#   2   bad arguments / invalid proposal
#   65  EX_DATAERR — invalid SHA / repo name
#   75  EX_TEMPFAIL — flock timeout (another pai-accept in flight)
#   77  EX_NOPERM — not a real SSH session (no sshd in process ancestry) and no
#                  root-owned local-accept marker; or a path-escape attempt as root
#
# shellcheck shell=bash
set -euo pipefail

PROG="pai-accept-guard"

die() { echo "${PROG}: $*" >&2; exit "${2:-1}"; }

# Trap accumulator (M3): every tempfile/lockfile appended here is removed on
# exit. Preserve the original exit code — the trap must not mask `die`'s
# chosen code (e.g. 77 for non-SSH). `set -u` + empty array would otherwise
# fail the trap and bash would exit 1.
CLEANUP=()
cleanup() {
  local rc=$?
  local f
  if [[ ${#CLEANUP[@]} -gt 0 ]]; then
    for f in "${CLEANUP[@]}"; do
      [[ -n "$f" ]] && rm -f "$f"
    done
  fi
  exit "$rc"
}
trap cleanup EXIT

# === 1. Real-SSH-session enforcement (forge-resistant) ====================
# pai-accept is the highest-privilege mutation: it pins trusted SHAs in
# /etc/pai/paths.env. It must be initiated by a human at a real SSH session,
# never by Hermes — an LLM reachable over remote chat platforms that could be
# prompt-injected into accepting a malicious upstream bump.
#
# We do NOT trust SSH_* env vars: an LLM controls its child-process env and can
# forge them. Instead we verify the real process ancestry up to sshd, which the
# agent's process tree never has. This stays "usable from anywhere": open a
# Tailscale SSH session from your phone/laptop and the check passes.
#
# Break-glass for non-SSH local admin / CI is a ROOT-OWNED marker file
# (/etc/pai/local-accept.allow, regular file, uid 0, mode 0600). A non-root
# process — including Hermes — cannot create it. Tests (non-root) may point the
# marker at a temp path via PAI_ACCEPT_LOCAL_ALLOW; that override is ignored
# when running as root, where the marker path is fixed.
has_sshd_ancestor() {
  # PAI_ACCEPT_ASSUME_NO_SSH only ever DENIES (tightens) — safe test aid to
  # simulate the no-SSH attacker case deterministically.
  [[ "${PAI_ACCEPT_ASSUME_NO_SSH:-}" == "1" ]] && return 1
  local pid="${PPID}" depth=0 comm ppid
  while [[ "${pid}" -gt 1 && "${depth}" -lt 32 ]]; do
    [[ -r "/proc/${pid}/comm" ]] || return 1
    comm="$(tr -d '\0' < "/proc/${pid}/comm" 2>/dev/null || echo '')"
    case "${comm}" in
      sshd|sshd-session) return 0 ;;
    esac
    ppid="$(awk '/^PPid:/{print $2; exit}' "/proc/${pid}/status" 2>/dev/null || echo 1)"
    [[ "${ppid}" =~ ^[0-9]+$ ]] || return 1
    pid="${ppid}"
    depth=$((depth + 1))
  done
  return 1
}

local_allow_ok() {
  # Marker path may be overridden for tests/dev. The security does NOT rely on
  # the path being fixed: when running as root (the only context that can mutate
  # the real /etc/pai/paths.env) the marker must be root-owned 0600, which a
  # non-root process such as Hermes cannot forge. At non-root the guard can't
  # write the real paths.env anyway, so an attacker-pointed marker gains nothing.
  local marker="${PAI_ACCEPT_LOCAL_ALLOW:-/etc/pai/local-accept.allow}"
  [[ -e "${marker}" ]] || return 1
  [[ -f "${marker}" && ! -L "${marker}" ]] || die "local-accept marker must be a regular file: ${marker}" 77
  # When this gate authorizes a ROOT mutation, demand strict root ownership +
  # 0600 so only a real root admin could have created it.
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    local owner mode
    owner="$(stat -c '%u' "${marker}" 2>/dev/null || echo -1)"
    mode="$(stat -c '%a' "${marker}" 2>/dev/null || echo 777)"
    [[ "${owner}" == "0" ]]   || die "local-accept marker must be owned by root: ${marker}" 77
    [[ "${mode}"  == "600" ]] || die "local-accept marker must be mode 0600: ${marker}" 77
  fi
  return 0
}

if ! has_sshd_ancestor && ! local_allow_ok; then
  die "refused: pai-accept needs a real SSH session (Tailscale SSH works from anywhere). Break-glass: create root-owned /etc/pai/local-accept.allow (mode 0600)." 77
fi

# === 2. Args ==============================================================
[[ $# -ge 1 ]] || die "usage: ${PROG} <proposal-id>" 2
ID="$1"
[[ "$ID" =~ ^[A-Za-z0-9._:T-]+$ ]] || die "invalid proposal id: $ID" 65

PROPOSALS_DIR="${PAI_PROPOSALS_DIR:-/var/lib/pai-anywhere/proposals}"
PATHS_ENV="${PAI_PATHS_ENV:-/etc/pai/paths.env}"

# === 2b. Root path lock (H2) ==============================================
# When running as root (typically via sudo wrapper), refuse non-canonical
# paths to prevent PAI_PATHS_ENV=/etc/shadow style arbitrary-file overwrite.
# Override env vars only honored when running as a non-root user.
if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
  case "$PATHS_ENV" in
    /etc/pai/paths.env) ;;
    *) die "refused: as root, paths.env must be /etc/pai/paths.env (got: $PATHS_ENV)" 77 ;;
  esac
  case "$PROPOSALS_DIR" in
    /var/lib/pai-anywhere/proposals) ;;
    *) die "refused: as root, proposals dir must be /var/lib/pai-anywhere/proposals" 77 ;;
  esac
fi

# Resolve symlinks; refuse path escape via symlink swap (root only). Both the
# paths.env target AND the proposals dir are checked — a symlinked proposals dir
# could otherwise feed a forged proposal into a root-privileged pin write.
if command -v readlink >/dev/null 2>&1 && [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
  PATHS_ENV_RESOLVED="$(readlink -f "$PATHS_ENV" 2>/dev/null || echo "$PATHS_ENV")"
  if [[ "$PATHS_ENV_RESOLVED" != "/etc/pai/paths.env" ]]; then
    die "refused: paths.env symlink escape detected (resolves to $PATHS_ENV_RESOLVED)" 77
  fi
  PROPOSALS_DIR_RESOLVED="$(readlink -f "$PROPOSALS_DIR" 2>/dev/null || echo "$PROPOSALS_DIR")"
  if [[ "$PROPOSALS_DIR_RESOLVED" != "/var/lib/pai-anywhere/proposals" ]]; then
    die "refused: proposals dir symlink escape detected (resolves to $PROPOSALS_DIR_RESOLVED)" 77
  fi
fi

PROPOSAL="${PROPOSALS_DIR}/${ID}.json"
[[ -f "$PROPOSAL" ]] || die "proposal not found: $PROPOSAL" 2

[[ -f "$PATHS_ENV" ]] || die "paths.env missing: $PATHS_ENV"
[[ -w "$PATHS_ENV" ]] || die "paths.env not writable: $PATHS_ENV"

# === 3. Parse proposal ====================================================
command -v jq >/dev/null 2>&1 || die "jq required but not on PATH"

REPO="$(jq -r .repo "$PROPOSAL")"
SHA="$(jq -r .targetSha "$PROPOSAL")"
LOG="$(jq -r .commits "$PROPOSAL")"

[[ -n "$REPO" && "$REPO" != "null" ]] || die "proposal missing .repo" 65
[[ "$REPO" =~ ^[A-Za-z0-9._-]+$ ]] || die "invalid repo name: $REPO" 65
[[ -n "$SHA" && "$SHA" != "null" ]] || die "proposal missing .targetSha" 65
[[ "$SHA" =~ ^[a-f0-9]{7,40}$ ]] || die "invalid SHA format: $SHA" 65

# Normalize repo name to an env key: uppercase, and both '-' and '.' → '_'.
# Watched repo names must be unique under this normalization (the curated
# PAI_WATCH_SOURCES set is). The '=' filter below is a FIXED-STRING match, so a
# '.' surviving in the key could no longer act as a regex wildcard regardless.
KEY="PAI_$(printf '%s' "$REPO" | tr 'a-z.-' 'A-Z__')_SHA"

# === 4. Atomic paths.env update under flock ===============================
# Lock dir in user runtime dir (M2): avoids /tmp symlink race that could
# truncate arbitrary file via `exec 9>"$LOCK"`.
LOCK_DEFAULT_DIR="${XDG_RUNTIME_DIR:-/run/user/${EUID:-$(id -u)}}/pai-accept"
LOCK="${PAI_ACCEPT_LOCK:-${LOCK_DEFAULT_DIR}/lock}"
LOCK_DIR="$(dirname "$LOCK")"
# `install -d -m 700` atomically creates the dir with the right mode (no
# mkdir-then-chmod TOCTOU; fails cleanly if the path exists as a non-directory).
install -d -m 700 "$LOCK_DIR" 2>/dev/null || die "cannot create lock dir: $LOCK_DIR"
# Refuse if LOCK is an existing symlink (anti-swap).
[[ -L "$LOCK" ]] && die "lock path is a symlink, refusing: $LOCK" 77
exec 9>"$LOCK" || die "cannot open lock: $LOCK"
flock -w "${PAI_ACCEPT_LOCK_TIMEOUT:-30}" 9 || die "another pai-accept in flight (lock timeout)" 75

TMP="$(mktemp "${PATHS_ENV}.XXXXXX")"
CLEANUP+=("$TMP")
# Drop any existing line for this key, preserving all OTHER pins. Use awk with a
# FIXED-STRING prefix test (not a grep regex): a repo name with regex
# metacharacters can't strip unrelated keys. awk returns 0 even on no-match, so a
# non-zero rc means a real read error — refuse rather than silently wipe pins.
set +e
awk -v k="${KEY}=" 'index($0, k) != 1' "$PATHS_ENV" > "$TMP"
awk_rc=$?
set -e
[[ "${awk_rc}" -eq 0 ]] || die "failed reading ${PATHS_ENV} (rc=${awk_rc}); refusing to drop pins" 1
printf '%s=%s\n' "$KEY" "$SHA" >> "$TMP"

# Preserve permissions of original
chmod --reference="$PATHS_ENV" "$TMP" 2>/dev/null || chmod 644 "$TMP"
mv "$TMP" "$PATHS_ENV"   # atomic on same filesystem

echo "${KEY}=${SHA}"

# === 5. Mark proposal accepted (also atomic via tmp+mv) ===================
TS="$(date -u +%FT%TZ)"
PTMP="$(mktemp "${PROPOSAL}.XXXXXX")"
CLEANUP+=("$PTMP")
jq --arg ts "$TS" '.status="accepted" | .acceptedAt=$ts' "$PROPOSAL" > "$PTMP"
mv "$PTMP" "$PROPOSAL"

# === 6. Optional arc review markdown =====================================
# AGPL boundary: filesystem write into pai-collab is allowed (MIT content
# flows into AGPL repo). NO embedding/linking/copying.
ARC_BASE="${PAI_COLLAB_DIR:-}"
ARC_DIR="${ARC_BASE}/projects/arc/reviews"
if [[ -n "$ARC_BASE" && -d "$ARC_DIR" && -w "$ARC_DIR" ]]; then
  SHA7="${SHA:0:7}"
  TODAY="$(date -u +%F)"
  REVIEW="${ARC_DIR}/${TODAY}-pai-watch-${REPO}-${SHA7}.md"
  # M4 fix: quoted heredoc + printf for attacker-controllable $LOG.
  # Without this, a malicious upstream commit subject like $(rm -rf ~) would
  # execute at heredoc-expansion time. ${LOG} comes from `git log %h %s` of
  # fetched upstream refs — any upstream maintainer is untrusted input.
  {
    printf '# Upstream bump review — %s @ %s\n\n' "$REPO" "$SHA7"
    printf '**Proposal**: %s\n' "$ID"
    printf '**Repo**: %s\n' "$REPO"
    printf '**Target SHA**: %s\n' "$SHA"
    printf '**Accepted**: %s\n' "$TS"
    printf '**Source**: pai-watch auto-detect\n\n'
    printf '## Commits\n\n'
    # Render $LOG (untrusted upstream commit subjects) as a markdown INDENTED
    # code block — every line prefixed with 4 spaces. There is no fence for a
    # subject containing ~~~ or ``` to break out of, so it cannot inject markdown.
    printf '%s\n' "$LOG" | sed 's/^/    /'
    printf '\n'
    printf '## Review\n\n'
    # shellcheck disable=SC2016  # backticks are markdown code-span, not shell sub
    printf 'Auto-generated via `pai-accept-guard %s`. Human approval recorded as SSH session on VPS.\n' "$ID"
  } > "$REVIEW"
  echo "$REVIEW"
fi

echo "accepted: ${ID} (${REPO} @ ${SHA:0:7})"
